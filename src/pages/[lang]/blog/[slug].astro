---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import { getCollection } from 'astro:content';
import { getTranslations, type Language } from '@/i18n';
import { isValidLocale } from '@/i18n/routing';
import Lang from '@/components/Lang.tsx';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const out: {
    params: { lang: string; slug: string };
    props: { post: (typeof posts)[number] };
  }[] = [];
  for (const lang of ['tr', 'en'] as const) {
    for (const post of posts) {
      out.push({
        params: { lang, slug: post.slug },
        props: { post },
      });
    }
  }
  return out;
}

const raw = Astro.params.lang;
if (!isValidLocale(raw)) {
  return Astro.redirect('/tr/blog', 302);
}
const lang: Language = raw;
const t = getTranslations(lang);
const prefix = `/${lang}`;

const { post } = Astro.props;

const { Content } = await post.render();
---

<BaseLayout
  title={`${lang === 'tr' && post.data.titleTr ? post.data.titleTr : post.data.title} - Atilla Mercimek`}
  description={lang === 'tr' && post.data.descriptionTr ? post.data.descriptionTr : post.data.description}
  locale={lang}
>
  <Section class="pt-32">
    <article class="mx-auto max-w-3xl">
      <!-- Header -->
      <header class="mb-12 scroll-reveal">
        <h1 class="mb-4 text-4xl font-bold text-light-text sm:text-5xl">
          {lang === 'tr' && post.data.titleTr ? post.data.titleTr : post.data.title}
        </h1>
        <p class="mb-6 text-xl text-light-muted">
          {lang === 'tr' && post.data.descriptionTr ? post.data.descriptionTr : post.data.description}
        </p>
        <div class="mb-6 flex flex-wrap items-center gap-4 text-sm text-light-muted">
          <div class="flex items-center gap-2">
            <svg
              class="h-4 w-4 text-accent-from/60"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
          {post.data.updatedDate && (
            <>
              <span class="text-light-muted/50">•</span>
              <div class="flex items-center gap-1">
                <span class="text-light-muted/70">{t.blog.updated}:</span>
                <time datetime={post.data.updatedDate.toISOString()}>
                  {post.data.updatedDate.toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
            </>
          )}
          <span class="text-light-muted/50">•</span>
          <div class="flex items-center gap-1">
            <svg
              class="h-4 w-4 text-accent-from/60"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span>{post.data.readTime} {t.blog.minRead}</span>
          </div>
        </div>
        {((lang === 'tr' && post.data.tagsTr && post.data.tagsTr.length > 0) || post.data.tags.length > 0) && (
          <div class="mt-4 flex flex-wrap gap-2">
            {(lang === 'tr' && post.data.tagsTr ? post.data.tagsTr : post.data.tags).map((tag: string) => (
              <span class="rounded-full border border-dark-border bg-dark-surface px-3 py-1.5 text-xs font-medium text-light-muted transition-colors hover:border-accent-from/50 hover:text-accent-from/80">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="prose prose-invert max-w-none scroll-reveal" data-lang={lang}>
        <Content components={{ Lang }} />
      </div>

      <!-- Footer -->
      <footer class="mt-16 border-t border-dark-border pt-8 scroll-reveal">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <a
            href={`${prefix}/blog`}
            class="group inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/[0.05] px-4 py-2 text-sm font-medium text-light-text transition-all hover:border-accent-from/50 hover:bg-white/10 hover:text-accent-from focus:outline-none focus:ring-2 focus:ring-accent-from/50"
          >
            <svg
              class="h-4 w-4 transition-transform group-hover:-translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              />
            </svg>
            {t.blog.backToBlog}
          </a>
          <a
            href={`${prefix}/contact`}
            class="group inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-accent-from to-accent-to px-4 py-2 text-sm font-semibold text-white transition-all hover:scale-105 hover:shadow-lg hover:shadow-accent-from/30 focus:outline-none focus:ring-2 focus:ring-accent-from/50"
          >
            {t.blog.discussPost}
            <svg
              class="h-4 w-4 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>
      </footer>
    </article>
  </Section>
</BaseLayout>

<style>
  .prose {
    @apply text-light-text;
  }

  .prose h2 {
    @apply mt-12 mb-4 text-2xl font-bold text-light-text first:mt-0;
    @apply scroll-mt-8;
  }

  .prose h3 {
    @apply mt-8 mb-3 text-xl font-semibold text-light-text;
    @apply scroll-mt-8;
  }

  .prose h4 {
    @apply mt-6 mb-2 text-lg font-semibold text-light-text;
  }

  .prose p {
    @apply mb-4 text-light-muted leading-relaxed;
  }

  .prose ul,
  .prose ol {
    @apply mb-4 ml-6 space-y-2 text-light-muted;
  }

  .prose li {
    @apply leading-relaxed;
  }

  .prose li::marker {
    @apply text-accent-from/60;
  }

  .prose code {
    @apply rounded bg-dark-surface px-1.5 py-0.5 text-sm font-mono text-accent-from;
    @apply border border-dark-border;
  }

  .prose pre {
    @apply mb-4 overflow-x-auto rounded-2xl border border-dark-border bg-dark-surface p-4;
    @apply shadow-lg;
  }

  .prose pre code {
    @apply bg-transparent p-0 text-light-text border-0;
  }

  .prose a {
    @apply text-accent-from underline transition-colors hover:text-accent-to;
    @apply decoration-2 decoration-accent-from/50 underline-offset-2;
  }

  .prose img {
    @apply my-8 rounded-2xl border border-dark-border;
    @apply shadow-lg;
  }

  .prose blockquote {
    @apply my-4 border-l-4 border-accent-from pl-4 italic text-light-muted;
    @apply bg-dark-surface/50 rounded-r-2xl py-2;
  }

  .prose hr {
    @apply my-8 border-dark-border;
  }

  .prose table {
    @apply w-full my-4 border-collapse;
  }

  .prose th {
    @apply border border-dark-border bg-dark-surface px-4 py-2 text-left font-semibold text-light-text;
  }

  .prose td {
    @apply border border-dark-border px-4 py-2 text-light-muted;
  }

  .prose strong {
    @apply font-semibold text-light-text;
  }

  .prose em {
    @apply italic;
  }
</style>
