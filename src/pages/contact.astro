---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import { getDefaultLanguage, getTranslations } from '@/i18n';

const lang = getDefaultLanguage();
const t = getTranslations(lang);

const email = 'mercimekatilla53@gmail.com';

const socialLinks = [
  {
    name: lang === 'tr' ? t.contact.social.github.name : 'GitHub',
    href: 'https://github.com/atillamrcmk',
    icon: 'github',
    description: lang === 'tr' ? t.contact.social.github.description : 'Check out my code and open source contributions',
  },
  {
    name: lang === 'tr' ? t.contact.social.linkedin.name : 'LinkedIn',
    href: 'https://linkedin.com/in/atilla-mercimek-6025b7222',
    icon: 'linkedin',
    description: lang === 'tr' ? t.contact.social.linkedin.description : 'Connect with me professionally',
  },
  {
    name: lang === 'tr' ? t.contact.social.email.name : 'Email',
    href: `mailto:${email}`,
    icon: 'mail',
    description: lang === 'tr' ? t.contact.social.email.description : 'Send me an email directly',
  },
];
---

<BaseLayout
  title={`${t.contact.title} - Atilla Mercimek`}
  description={t.contact.subtitle}
>
  <Section class="pt-24 sm:pt-28 md:pt-32">
    <div class="mx-auto max-w-3xl">
      <!-- Header -->
      <div class="mb-8 sm:mb-12 scroll-reveal">
        <h1 class="heading-1 mb-3 sm:mb-4 text-light-text">
          {t.contact.title}
        </h1>
        <p class="body-large text-light-muted">
          {t.contact.subtitle}
        </p>
      </div>

      <!-- Contact Form (Placeholder) -->
      <div class="mb-8 sm:mb-12 scroll-reveal">
        <div class="card">
          <h2 class="heading-3 mb-3 sm:mb-4 text-light-text">{t.contact.form.title}</h2>
          <p class="body-small mb-4 sm:mb-6 text-light-muted">
            {t.contact.form.note}
          </p>
          <form class="space-y-4 sm:space-y-6" id="contact-form">
            <div>
              <label
                for="name"
                class="mb-2 block text-sm font-medium text-light-text"
              >
                {t.contact.form.name}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-2xl border border-dark-border bg-dark-bg px-4 py-3 text-light-text placeholder:text-light-muted focus:border-accent-from focus:outline-none focus:ring-2 focus:ring-accent-from/20 transition-colors"
                placeholder={t.contact.form.namePlaceholder}
              />
            </div>
            <div>
              <label
                for="email"
                class="mb-2 block text-sm font-medium text-light-text"
              >
                {t.contact.form.email}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-2xl border border-dark-border bg-dark-bg px-4 py-3 text-light-text placeholder:text-light-muted focus:border-accent-from focus:outline-none focus:ring-2 focus:ring-accent-from/20 transition-colors"
                placeholder={t.contact.form.emailPlaceholder}
              />
            </div>
            <div>
              <label
                for="message"
                class="mb-2 block text-sm font-medium text-light-text"
              >
                {t.contact.form.message}
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full rounded-2xl border border-dark-border bg-dark-bg px-4 py-3 text-light-text placeholder:text-light-muted focus:border-accent-from focus:outline-none focus:ring-2 focus:ring-accent-from/20 transition-colors resize-none"
                placeholder={t.contact.form.messagePlaceholder}
              />
            </div>
            <div id="form-error" class="hidden rounded-2xl border border-red-500/50 bg-red-500/10 px-3 sm:px-4 py-2.5 sm:py-3 body-small text-red-400"></div>
            <div class="flex flex-col gap-3 sm:gap-4">
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary inline-flex items-center justify-center gap-2 w-full sm:w-auto"
              >
                {t.contact.form.sendViaEmail}
                <svg
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
              </button>
              <button
                type="button"
                id="copy-email-btn"
                class="btn-secondary inline-flex items-center justify-center gap-2 w-full sm:w-auto"
              >
                {t.contact.form.copyEmail}
                <svg
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  />
                </svg>
              </button>
            </div>
            <p class="body-small text-light-muted">
              {t.contact.form.clickToOpen}
            </p>
          </form>
        </div>
      </div>

      <!-- Social Links -->
      <div class="scroll-reveal">
        <h2 class="heading-3 mb-4 sm:mb-6 text-light-text">{t.contact.social.title}</h2>
        <div class="grid gap-4 sm:gap-4 md:grid-cols-3">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="card card-hover group transition-all hover:border-accent-from/50 hover:shadow-lg hover:shadow-accent-from/10 min-h-[120px] flex flex-col"
            >
              <div class="mb-3">
                <svg
                  class="h-7 w-7 sm:h-8 sm:w-8 text-accent-from transition-transform group-hover:scale-110"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  {link.icon === 'github' && (
                    <path
                      d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
                    />
                  )}
                  {link.icon === 'linkedin' && (
                    <path
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    />
                  )}
                  {link.icon === 'mail' && (
                    <path
                      d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                    />
                  )}
                </svg>
              </div>
              <h3 class="heading-4 mb-1 text-light-text">{link.name}</h3>
              <p class="body-small text-light-muted">{link.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

<script>
  // Toast notification function
  let currentToast: HTMLElement | null = null;

  function showToast(message: string) {
    // Remove existing toast
    if (currentToast) {
      currentToast.remove();
    }

    // Create toast element
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-4 left-1/2 z-50 -translate-x-1/2 rounded-full border border-white/10 bg-dark-surface px-6 py-3 text-sm font-medium text-light-text backdrop-blur-md transition-all opacity-0 translate-y-2';
    toast.textContent = message;
    toast.setAttribute('role', 'alert');
    toast.setAttribute('aria-live', 'polite');
    document.body.appendChild(toast);
    currentToast = toast;

    // Trigger animation
    requestAnimationFrame(() => {
      toast.classList.remove('opacity-0', 'translate-y-2');
      toast.classList.add('opacity-100', 'translate-y-0');
    });

    // Remove after duration
    setTimeout(() => {
      toast.classList.remove('opacity-100', 'translate-y-0');
      toast.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        toast.remove();
        currentToast = null;
      }, 300);
    }, 2000);
  }

  // Form validation and email generation
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const copyEmailBtn = document.getElementById('copy-email-btn') as HTMLButtonElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const nameInput = document.getElementById('name') as HTMLInputElement;
  const messageInput = document.getElementById('message') as HTMLTextAreaElement;

  const email = 'mercimekatilla53@gmail.com';
  const lang = localStorage.getItem('language') || 'tr';

  // Email validation
  function validateEmail(email: string): boolean {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return re.test(email);
  }

  // Show error message
  function showError(message: string) {
    formError.textContent = message;
    formError.classList.remove('hidden');
    formError.classList.add('block');
  }

  // Hide error message
  function hideError() {
    formError.classList.add('hidden');
    formError.classList.remove('block');
  }

  // Form submission
  if (form && submitBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      hideError();

      const name = nameInput.value.trim();
      const emailValue = emailInput.value.trim();
      const message = messageInput.value.trim();

      // Validation
      if (!name || !emailValue || !message) {
        showError(lang === 'tr' ? 'Lütfen tüm alanları doldurun' : 'Please fill in all fields');
        return;
      }

      if (!validateEmail(emailValue)) {
        showError(lang === 'tr' ? 'Geçerli bir e-posta adresi girin' : 'Please enter a valid email address');
        emailInput.focus();
        return;
      }

      // Create email link with form data
      const subject = encodeURIComponent(`Portfolio İletişim - ${name}`);
      const body = encodeURIComponent(
        `Merhaba,\n\n` +
        `Ad: ${name}\n` +
        `E-posta: ${emailValue}\n\n` +
        `Mesaj:\n${message}\n\n` +
        `---\nBu mesaj portfolio sitesinden gönderilmiştir.`
      );

      const mailtoLink = `mailto:${email}?subject=${subject}&body=${body}`;
      
      // Open email client
      window.location.href = mailtoLink;

      // Show success message
      const successMsg = lang === 'tr' ? 'E-posta istemciniz açılıyor...' : 'Opening your email client...';
      showToast(successMsg);
    });
  }

  // Copy email to clipboard
  if (copyEmailBtn) {
    copyEmailBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(email);
        const copiedText = lang === 'tr' ? 'E-posta adresi kopyalandı!' : 'Email address copied!';
        showToast(copiedText);
      } catch (err) {
        console.error('Failed to copy:', err);
        const failedText = lang === 'tr' ? 'Kopyalama başarısız' : 'Failed to copy';
        showToast(failedText);
      }
    });
  }

  // Real-time email validation
  if (emailInput) {
    emailInput.addEventListener('blur', () => {
      const emailValue = emailInput.value.trim();
      if (emailValue && !validateEmail(emailValue)) {
        emailInput.classList.add('border-red-500');
        emailInput.classList.remove('border-dark-border');
      } else {
        emailInput.classList.remove('border-red-500');
        emailInput.classList.add('border-dark-border');
      }
    });

    emailInput.addEventListener('input', () => {
      if (emailInput.classList.contains('border-red-500')) {
        const emailValue = emailInput.value.trim();
        if (validateEmail(emailValue)) {
          emailInput.classList.remove('border-red-500');
          emailInput.classList.add('border-dark-border');
          hideError();
        }
      }
    });
  }

  // Clear error on input
  [nameInput, emailInput, messageInput].forEach((input) => {
    if (input) {
      input.addEventListener('input', () => {
        hideError();
      });
    }
  });
</script>

