---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Badge from '@/components/Badge.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout
  title={`${project.data.title} - Atilla`}
  description={project.data.description}
>
  <Section class="pt-32">
    <!-- Project Header -->
    <div class="mb-12 scroll-reveal">
      <div class="mb-6">
        <span class="text-sm font-semibold text-accent-from">
          {project.data.category}
        </span>
        <h1 class="mt-2 text-4xl font-bold text-light-text sm:text-5xl md:text-6xl">
          {project.data.title}
        </h1>
        <p class="mt-4 text-xl text-light-muted">{project.data.tagline}</p>
      </div>

      <div class="flex flex-wrap gap-4">
        {project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-2xl border border-dark-border bg-dark-surface px-4 py-2 text-sm font-medium text-light-text transition-colors hover:border-accent-from/50"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
              />
            </svg>
            GitHub
          </a>
        )}
        {project.data.demo && (
          <a
            href={project.data.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-accent-from to-accent-to px-4 py-2 text-sm font-medium text-white transition-transform hover:scale-105"
          >
            Live Demo
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        )}
      </div>
    </div>

    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <article class="prose prose-invert max-w-none scroll-reveal">
          <Content />
        </article>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <!-- Project Meta -->
          <div class="card scroll-reveal">
            <h3 class="mb-4 text-lg font-semibold text-light-text">
              Project Details
            </h3>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-light-muted">Date</dt>
                <dd class="font-medium text-light-text">
                  {new Date(project.data.date).toLocaleDateString('tr-TR', {
                    year: 'numeric',
                    month: 'long',
                  })}
                </dd>
              </div>
              <div>
                <dt class="text-light-muted">Role</dt>
                <dd class="font-medium text-light-text">{project.data.role}</dd>
              </div>
              <div>
                <dt class="text-light-muted">Platform</dt>
                <dd class="font-medium text-light-text">
                  {project.data.platform}
                </dd>
              </div>
            </dl>
          </div>

          <!-- Technologies -->
          <div class="card scroll-reveal">
            <h3 class="mb-4 text-lg font-semibold text-light-text">Stack</h3>
            <div class="flex flex-wrap gap-2">
              {project.data.technologies.map((tech: string) => (
                <Badge text={tech} />
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>

<style>
  .prose {
    @apply text-light-text;
  }

  .prose h2 {
    @apply mt-12 mb-4 text-2xl font-bold text-light-text first:mt-0;
  }

  .prose h3 {
    @apply mt-8 mb-3 text-xl font-semibold text-light-text;
  }

  .prose p {
    @apply mb-4 text-light-muted leading-relaxed;
  }

  .prose ul,
  .prose ol {
    @apply mb-4 ml-6 space-y-2 text-light-muted;
  }

  .prose li {
    @apply leading-relaxed;
  }

  .prose code {
    @apply rounded bg-dark-surface px-1.5 py-0.5 text-sm font-mono text-accent-from;
  }

  .prose pre {
    @apply mb-4 overflow-x-auto rounded-2xl border border-dark-border bg-dark-surface p-4;
  }

  .prose pre code {
    @apply bg-transparent p-0 text-light-text;
  }

  .prose a {
    @apply text-accent-from underline transition-colors hover:text-accent-to;
  }

  .prose img {
    @apply my-8 rounded-2xl border border-dark-border;
  }

  .prose blockquote {
    @apply my-4 border-l-4 border-accent-from pl-4 italic text-light-muted;
  }
</style>




