---
import Badge from './Badge.astro';
import { getTranslations, type Language } from '@/i18n';

interface Props {
  number: string;
  title: string;
  description: string;
  tags: string[];
  href: string;
  locale: Language;
}

const { number, title, description, tags, href, locale } = Astro.props;
const t = getTranslations(locale);
---

<a
  href={href}
  class="card card-hover group block scroll-reveal"
  aria-label={`View project: ${title}`}
  target={href.startsWith('http') ? '_blank' : undefined}
  rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
>
  <div class="flex flex-col gap-4 md:flex-row md:items-start">
    <div class="flex-shrink-0">
      <span class="text-6xl font-bold text-light-muted/20 md:text-8xl">
        {number}
      </span>
    </div>
    <div class="flex-1 space-y-4">
      <div>
        <h3 class="mb-2 text-2xl font-bold text-light-text">{title}</h3>
        <p class="text-light-muted">{description}</p>
      </div>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <Badge text={tag} />
        ))}
      </div>
      <div class="flex items-center gap-2 text-sm font-medium text-accent-from transition-transform group-hover:translate-x-1">
        {href.startsWith('http') ? t.projects.viewOnGitHub : t.projects.viewCaseStudy}
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          {href.startsWith('http') ? (
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
            />
          ) : (
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            />
          )}
        </svg>
      </div>
    </div>
  </div>
</a>

